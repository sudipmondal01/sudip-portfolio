
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .animate-marquee-infinite {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      width: fit-content;
      animation: marquee 40s linear infinite;
      will-change: transform;
    }

    .animate-marquee-infinite:hover {
      animation-play-state: paused;
    }
  